# =============================================================================
# .gitignore — fabric-core-api
# -----------------------------------------------------------------------------
# Sections:
#   1. Project — rendered config files (from *.template) and generated code
#   2. Application data — runtime artifacts, exports, DB volumes
#   3. Secrets — environment files (NEVER commit)
#   4. Python — bytecode, packaging, virtualenvs
#   5. Testing & coverage
#   6. Type checkers & tool caches
#   7. Editors & IDEs
#   8. macOS (development hosts)
#   9. Linux (deployment hosts)
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Project — rendered config files & generated code
# -----------------------------------------------------------------------------
# *.template files are committed; their rendered counterparts are local only.
docker-compose.yml
nginx/default.conf
vouch/config*
!vouch/config.yml.template

# Connexion / swagger code generation outputs (regenerated on demand).
python-flask-server-generated/
server_archive/

# Database migrations are generated locally per deployment.
migrations/


# -----------------------------------------------------------------------------
# 2. Application data — runtime artifacts (never commit)
# -----------------------------------------------------------------------------
logs/
pg_data/
misc_local_files/

# Per-table JSON exports/imports
server/swagger_server/backup/data/
server/swagger_server/backup/data/*.json

# Full-backup script output (./full-backup-<timestamp>/ and tarballs)
full-backup-*/
full-backup-*.tar.gz


# -----------------------------------------------------------------------------
# 3. Secrets — environment files
# -----------------------------------------------------------------------------
.env
.env.*
!env.template


# -----------------------------------------------------------------------------
# 4. Python — bytecode, packaging, virtualenvs
# -----------------------------------------------------------------------------
# Bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtualenvs (covers `venv`, `.venv`, `env`, `ENV`, and timestamped backups)
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
pyvenv.cfg
pip-selfcheck.json
pip-log.txt
pip-delete-this-directory.txt


# -----------------------------------------------------------------------------
# 5. Testing & coverage
# -----------------------------------------------------------------------------
.tox/
.nox/
.cache/
.pytest_cache/
.hypothesis/
htmlcov/
cover/
.coverage
.coverage.*
coverage.xml
nosetests.xml
*.cover
*.py,cover


# -----------------------------------------------------------------------------
# 6. Type checkers & tool caches
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/


# -----------------------------------------------------------------------------
# 7. Editors & IDEs
# -----------------------------------------------------------------------------
# JetBrains (PyCharm, IntelliJ)
.idea/

# VS Code (keep this entry even if you don't use VSCode — contributors might)
.vscode/

# Vim / Neovim swap & undo files
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-workspace
*.sublime-project

# Claude Code / agent state (local only)
.claude/


# -----------------------------------------------------------------------------
# 8. macOS (development hosts)
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
._*               # AppleDouble resource forks (e.g. ._filename)
.Spotlight-V100
.Trashes
.fseventsd
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Files that may appear on network/USB volumes mounted under macOS
.AppleDB
.AppleDesktop
Network\ Trash\ Folder
Temporary\ Items
.apdisk


# -----------------------------------------------------------------------------
# 9. Linux (deployment hosts)
# -----------------------------------------------------------------------------
*~                # backup files (already covered above; harmless duplicate)
.fuse_hidden*
.directory        # KDE
.Trash-*          # KDE/GNOME trash
.nfs*             # stale NFS handles
core              # core dumps
*.pid             # service pid files (e.g. uWSGI)
