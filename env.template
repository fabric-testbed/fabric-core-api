# =============================================================================
# Core API environment configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env`, fill in real values, then `source .env` before
# running the server (or before `docker compose up` — Compose reads it as well).
#
# Values marked CHANGE-ME contain placeholders that MUST be set per deployment.
# Values marked LOCAL/DOCKER toggle between local development and Docker
# Compose deployment — uncomment the appropriate line.
#
# Sections:
#   1.  Core API server
#   2.  Postgres database
#   3.  Authentication (Vouch / Nginx CORS)
#   4.  COmanage Registry (API + COU mappings)
#   5.  Background tasks (timeout intervals)
#   6.  SSH key management
#   7.  SMTP (outbound email)
#   8.  Projects (lifecycle)
#   9.  External FABRIC services
#   10. Service-account auth tokens
#   11. Runtime (Python / Flask)
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Core API server
# -----------------------------------------------------------------------------
# DEPLOYMENT_TIER: one of {alpha, beta, production} — controls which tag sets
#   and feature flags are loaded at startup.
# CO_USER_IDENTIFIER: which COmanage identifier type to match users on.
# USER_UPDATE_FREQUENCY_IN_SECONDS: minimum interval between COmanage syncs
#   for a given user when their profile is fetched.
# DEFAULT/MAX_LIMIT: pagination defaults for list endpoints.
# JSON_RESPONSE_INDENT: pretty-print indent for JSON responses (0 = compact).
export CORE_API_DEPLOYMENT_TIER=alpha
export CORE_API_SERVER_URL=https://127.0.0.1:8443
export CORE_API_CO_USER_IDENTIFIER=registryid
export CORE_API_USER_UPDATE_FREQUENCY_IN_SECONDS=60
export CORE_API_DEFAULT_LIMIT=5
export CORE_API_MAX_LIMIT=20
export CORE_API_JSON_RESPONSE_INDENT=2
export CORE_API_DEFAULT_FACILITY=FABRIC
export CORE_API_401_UNAUTHORIZED_TEXT="Please Log in (or Sign up) on the FABRIC Portal"

# Maximum carousel items shown on the announcements endpoint.
export MAX_ACTIVE_CAROUSEL_ITEMS=10


# -----------------------------------------------------------------------------
# 2. Postgres database
# -----------------------------------------------------------------------------
# POSTGRES_SERVER: hostname for the DB. Use '127.0.0.1' for local dev (Postgres
#   running directly or port-forwarded), or 'database' for Docker Compose
#   (resolves to the database service in the core-api network).
# PGDATA / PGDATA_HOST: in-container data dir and host bind-mount path.
#export POSTGRES_SERVER=127.0.0.1   # LOCAL development
export POSTGRES_SERVER=database     # DOCKER deployment
export POSTGRES_PORT=5432
export POSTGRES_USER=postgres
export POSTGRES_PASSWORD=xxxx-xxxx-xxxx-xxxx   # CHANGE-ME
export POSTGRES_DB=postgres
export PGDATA=/var/lib/postgresql/data/pg_data
export PGDATA_HOST=./data


# -----------------------------------------------------------------------------
# 3. Authentication (Vouch Proxy + Nginx CORS)
# -----------------------------------------------------------------------------
# VOUCH_COOKIE_NAME: must match `vouch.cookie.name` in vouch/config.yml.
# VOUCH_JWT_SECRET: must match `vouch.jwt.secret` in vouch/config.yml
#   (≥44 chars / 256 bits; shared across all Vouch instances in a cluster).
# NGINX_ACCESS_CONTROL_ALLOW_ORIGIN: CORS origin allowed by the nginx proxy —
#   set to the URL the browser uses to reach the API.
export VOUCH_COOKIE_NAME=COOKIE_NAME              # CHANGE-ME
export VOUCH_JWT_SECRET="xxxx-xxxx-xxxx-xxxx"     # CHANGE-ME
export NGINX_ACCESS_CONTROL_ALLOW_ORIGIN="https://127.0.0.1:8443"


# -----------------------------------------------------------------------------
# 4. COmanage Registry
# -----------------------------------------------------------------------------
# API user / pass / org context — see fabric_comanage_api docs for setup.
# SSH_KEY_AUTHENTICATOR_ID: id of the SSH key authenticator plugin in COmanage,
#   used when pushing/pulling user SSH keys.
export COMANAGE_API_USER=co_123.api-user-name        # CHANGE-ME
export COMANAGE_API_PASS=xxxx-xxxx-xxxx-xxxx        # CHANGE-ME
export COMANAGE_API_CO_NAME=RegistryName            # CHANGE-ME
export COMANAGE_API_CO_ID=123                       # CHANGE-ME
export COMANAGE_API_URL=https://FQDN_OF_REGISTRY    # CHANGE-ME
export COMANAGE_API_SSH_KEY_AUTHENTICATOR_ID=123    # CHANGE-ME

# COU (Collaborative Org Unit) IDs and Names. COU_NAME_* values are
# case-sensitive and must match the COU's `name` column in COmanage exactly.
# These map authorization roles to COmanage groups (see response_code/decorators.py).
export COU_ID_FACILITY_OPERATORS=100   # CHANGE-ME
export COU_ID_FACILITY_VIEWERS=101     # CHANGE-ME
export COU_ID_PROJECT_ADMINS=108       # CHANGE-ME
export COU_ID_PROJECTS=103             # CHANGE-ME
export COU_ID_ACTIVE_USERS=104         # CHANGE-ME
export COU_ID_APPROVAL_COMMITTEE=105   # CHANGE-ME
export COU_ID_JUPYTERHUB=106           # CHANGE-ME
export COU_ID_PORTAL_ADMINS=107        # CHANGE-ME
export COU_NAME_FACILITY_OPERATORS=facility-operators
export COU_NAME_FACILITY_VIEWERS=facility-viewers
export COU_NAME_PROJECT_ADMINS=project-admins
export COU_NAME_PROJECTS=projects
export COU_NAME_ACTIVE_USERS=fabric-active-users
export COU_NAME_APPROVAL_COMMITTEE=approval-committee
export COU_NAME_JUPYTERHUB=Jupyterhub
export COU_NAME_PORTAL_ADMINS=portal-admins


# -----------------------------------------------------------------------------
# 5. Background tasks (TaskTimeoutTracker intervals)
# -----------------------------------------------------------------------------
# Each task runs at most once per TIMEOUT_IN_SECONDS, triggered by /start.
#   CAM = Core API Metrics rollup
#   PSK = Public Signing Key cache refresh (Credential Manager)
#   TRL = Token Revocation List cache refresh
# DESCRIPTION/NAME pairs are written to the task_timeout_tracker table.
export CAM_DESCRIPTION='Core API Metrics'
export CAM_NAME='core_api_metrics'
export CAM_TIMEOUT_IN_SECONDS=3600
export PSK_DESCRIPTION='Public Signing Key'
export PSK_NAME='public_signing_key'
export PSK_TIMEOUT_IN_SECONDS=86400
export TRL_DESCRIPTION='Token Revocation List'
export TRL_NAME='token_revocation_list'
export TRL_TIMEOUT_IN_SECONDS=300


# -----------------------------------------------------------------------------
# 6. SSH key management
# -----------------------------------------------------------------------------
# ALGORITHM: key type ("rsa" or "ecdsa") generated for new keys.
# *_KEY_VALIDITY_DAYS: lifetime of bastion vs. sliver keys.
# GARBAGE_COLLECT_AFTER_DAYS: days past expiry before keys are purged.
# QTY_LIMIT: max keys a single user may hold concurrently.
# SSH_KEY_SECRET: shared secret the bastion host presents when calling
#   /bastionkeys (validated by @secret_required decorator).
export SSH_KEY_ALGORITHM="ecdsa"
export SSH_BASTION_KEY_VALIDITY_DAYS=5
export SSH_SLIVER_KEY_VALIDITY_DAYS=10
export SSH_GARBAGE_COLLECT_AFTER_DAYS=10
export SSH_KEY_SECRET="xxxx-xxxx-xxxx-xxxx"        # CHANGE-ME
export SSH_KEY_QTY_LIMIT=5


# -----------------------------------------------------------------------------
# 7. SMTP (outbound notifications)
# -----------------------------------------------------------------------------
# Used by the task monitor for SSH key expiry warnings and other notifications.
export SMTP_SERVER='mail.example.com'              # CHANGE-ME
export SMTP_PORT=587
export SMTP_USER='some_user'                       # CHANGE-ME
export SMTP_PASSWORD='xxxx-xxxx-xxxx-xxxx'         # CHANGE-ME
export SMTP_FROM_EMAIL='some_user@example.com'     # CHANGE-ME
export SMTP_REPLY_TO_EMAIL='no-reply@example.com'  # CHANGE-ME


# -----------------------------------------------------------------------------
# 8. Projects (lifecycle)
# -----------------------------------------------------------------------------
# RENEWAL_PERIOD: default project duration (also used for renewal extensions).
# RETIRE_POST_EXPIRY: grace period after expiry before a project is retired.
export PROJECTS_RENEWAL_PERIOD_IN_DAYS=365
export PROJECTS_RETIRE_POST_EXPIRY_IN_DAYS=365


# -----------------------------------------------------------------------------
# 9. External FABRIC services
# -----------------------------------------------------------------------------
# FABRIC_CORE_API: public URL of THIS API (used in self-referential links).
# FABRIC_CREDENTIAL_MANAGER: URL of the credential-manager service for JWT
#   issuance and the public signing key endpoint.
export FABRIC_CORE_API=https://COREAPI                       # CHANGE-ME
export FABRIC_CREDENTIAL_MANAGER=https://CREDENTIALMANAGER   # CHANGE-ME


# -----------------------------------------------------------------------------
# 10. Service-account auth tokens
# -----------------------------------------------------------------------------
# Bearer tokens accepted by service-only endpoints (validated in decorators.py).
#   ANSIBLE_*    — used by Ansible automation runs
#   READONLY_*   — read-only consumers (dashboards, reporting)
#   SERVICES_*   — peer FABRIC services (paired with SERVICE_ACCOUNT_UUID)
export ANSIBLE_AUTHORIZATION_TOKEN='xxxx-xxxx-xxxx-xxxx'                    # CHANGE-ME
export READONLY_AUTHORIZATION_TOKEN='xxxx-xxxx-xxxx-xxxx'                   # CHANGE-ME
export SERVICES_AUTHORIZATION_TOKEN='xxxx-xxxx-xxxx-xxxx'                   # CHANGE-ME
export SERVICE_ACCOUNT_UUID='xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'          # CHANGE-ME


# -----------------------------------------------------------------------------
# 11. Runtime (Python / Flask)
# -----------------------------------------------------------------------------
# PYTHONPATH must include the `server/` dir so `swagger_server.*` imports work.
# Use the LOCAL line when running outside Docker; the DOCKER line points at
# the in-container paths.
#export PYTHONPATH=./server:./venv/bin/python3:${PYTHONPATH}             # LOCAL development
export PYTHONPATH=/code/server:/code/.venv/bin/python3:${PYTHONPATH}     # DOCKER deployment

export FLASK_APP=swagger_server.__main__:app
